# Slack App Credentials
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here
SLACK_APP_TOKEN=xapp-your-app-token-here

# Server Configuration
PORT=3000

# Obsidian Local REST API Configuration
OBSIDIAN_API_URL=http://localhost:27123
OBSIDIAN_API_KEY=your-obsidian-api-key-here
OBSIDIAN_VAULT_NAME=your-vault-name

# Optional: Customize the folder path in Obsidian where messages will be saved
OBSIDIAN_FOLDER=Slack Messages
